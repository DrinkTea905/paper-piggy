  "matching": {
    "keys": ["issn", "eissn", "normalizedName"],
    "normalize": ["trim", "去《》和空格", "全半角归一", "简繁归一", "拉丁字母转小写"],
    "fallback": "刊名模糊匹配 ≥0.9 才自动采纳，否则标记待人工确认"
  },

  "resolution": {
    "strategy": "priority-max",
    "priorityOrder": ["clsci", "law_review_top", "tw_law", "tssci_law", "abs", "ft50", "utd24", "cssci", "ssci_law_authority", "ami", "ssci", "pku", "fms", "sjr", "ahci", "erih", "newspaper", "warning"],
    "ifAdjust": "base * (1 + ifStrength * percentileInDiscipline(if))",
    "ifEnabled": true,
    "_comment_ifEnabled": "已开启知网复合影响因子(if_cnki)微调：base×(1+ifStrength×该刊复合IF在全库的分位[0-1])。D_纯人文 ifStrength=0 不受影响；无 if_cnki 数据的刊自动跳过、不报错。数据源 catalogs/if_cnki.json。",
    "unknownDefault": "T5",
    "output": "clamp(score * coeffByOrigin, 0, 1)",
    "explain": true
  }
}
